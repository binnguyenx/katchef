{
  "expo": {
    "name": "KatChef",
    "slug": "katchef-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "katchef",
    "description": "KatChef Phase 1 frontend built with Expo, React Native, Firebase client SDK, and mock-safe API fallbacks.",
    "platforms": ["ios", "android", "web"],
    "assetBundlePatterns": ["**/*"],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F1"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow KatChef to access your camera for KatLens scans."
        }
      ]
    ]
  }
}
