# Gemini (chatbot + optional vision assist)
GEMINI_API_KEY=
# Use a model enabled for your API key (e.g. gemini-1.5-flash, gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash

# Google Cloud Vision — path to service account JSON, or leave empty if using ADC
GOOGLE_APPLICATION_CREDENTIALS=

# If true, vision/chat return deterministic mock data (good for local dev without keys)
MOCK_MODE=false

# Firebase Admin SDK (optional — virtual fridge / persistence)
FIREBASE_CREDENTIALS_PATH=
